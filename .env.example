# Reference values for local SAGE wiring.
#
# The Python backend currently stores runtime settings in SQLite through the
# daemon settings API. This file is intentionally a human-readable checklist for
# machine-local values that should not be committed in .env.local.

SAGE_DAEMON_URL=http://127.0.0.1:8765
SAGE_OLLAMA_URL=http://127.0.0.1:11434
SAGE_MODEL_NAME=gemma4
# Lower-RAM alternative for planner use:
# SAGE_MODEL_NAME=qwen2.5:3b
# SAGE_OLLAMA_NUM_CTX=2048
# SAGE_OLLAMA_KEEP_ALIVE=30s
SAGE_WHISPER_ENDPOINT=http://127.0.0.1:2022/v1

# Example only. Point runtime settings at your real local model file.
SAGE_WHISPER_MODEL_PATH=/absolute/path/to/ggml-model.bin

# Piper is optional if disabled in runtime settings.
SAGE_PIPER_BINARY_PATH=piper
SAGE_PIPER_VOICE_PATH=/absolute/path/to/piper-voice.onnx
SAGE_AUDIO_PLAYER=ffplay

SAGE_AUDIO_INPUT=default
SAGE_DATA_DIR=.sage
SAGE_DATABASE_PATH=.sage/sage.db
